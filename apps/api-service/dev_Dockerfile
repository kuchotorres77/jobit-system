FROM node:20-alpine
RUN apk update && apk upgrade && apk add --no-cache git
WORKDIR /jobit/api
COPY package.json package-lock.json ./
COPY .env.docker .env
# COPY ecosystem.config.js ecosystem.config.js
RUN npm install
RUN npm install -g nodemon
COPY . .
RUN npm run tsc
EXPOSE 3000

CMD ["nodemon", "--watch", ".", "--exec", "npm", "start"]
