NODE_ENV=development
PORT=3000

# PostgreSQL (docker-compose expone postgres en 5435 para desarrollo local)
DATABASE_URL=postgresql://jobit:jobit@localhost:5435/jobit?schema=public

# JWT
JWT_SECRET=cambiar-por-un-secreto-largo-y-aleatorio
JWT_EXPIRES_IN=2h

# Almacenamiento local de archivos subidos
STORAGE_DIR=./storage
