NODE_ENV=development
PORT=3000

# PostgreSQL (docker-compose expone postgres en 5435 para desarrollo local)
DATABASE_URL=postgresql://jobit:jobit@localhost:5435/jobit?schema=public

# JWT
JWT_SECRET=cambiar-por-un-secreto-largo-y-aleatorio
JWT_EXPIRES_IN=2h
# Vigencia de los refresh tokens, en días
JWT_REFRESH_TTL_DAYS=7

# Almacenamiento local de archivos subidos
STORAGE_DIR=./storage

# OAuth de Google (Google Cloud Console → credenciales → OAuth client ID tipo Web)
# Vacío = login con Google deshabilitado
GOOGLE_CLIENT_ID=

# Email (configurar con tu proveedor SMTP)
# Gmail: habilitar "App Password" en tu cuenta Google y poner el App Password en MAIL_PASS
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_SECURE=false
MAIL_USER=
MAIL_PASS=
MAIL_FROM=Jobit <noreply@jobit.app>
APP_URL=http://localhost
