generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [unaccent]
}

enum Sexo {
  FEMENINO
  MASCULINO
}

enum DiaSemana {
  LUNES
  MARTES
  MIERCOLES
  JUEVES
  VIERNES
  SABADO
  DOMINGO
  FERIADOS
}

enum TipoContacto {
  FIJO
  CELULAR
}

enum Role {
  CUSTOMER
  PROVIDER
  ADMIN
}

enum TipoEmailToken {
  VERIFICACION
  RECUPERO_PASSWORD
}

model User {
  id               String         @id @default(uuid())
  nombre           String
  apellido         String
  // Opcionales: las cuentas creadas vía Google no tienen documento ni password
  documento        String?        @unique
  email            String         @unique
  password         String?
  sexo             Sexo?
  role             Role           @default(CUSTOMER)
  emailVerificado  Boolean        @default(false)
  prestador        Prestador?
  contactos        Contacto[]
  direcciones      Direccion[]
  archivos         StorageFile[]
  refreshTokens    RefreshToken[]
  reviews          Review[]
  favoritos        Favorito[]
  votosReview      Voto[]
  emailTokens      EmailToken[]
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  @@map("users")
}

model RefreshToken {
  id        String    @id @default(uuid())
  tokenHash String    @unique
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
  @@map("refresh_tokens")
}

model Contacto {
  id     String       @id @default(uuid())
  tipo   TipoContacto
  valor  String
  activo Boolean      @default(true)
  userId String
  user   User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("contactos")
}

model Direccion {
  id           String  @id @default(uuid())
  calle        String
  codigoPostal String
  provincia    String
  departamento String?
  localidad    String?
  barrio       String?
  pais         String  @default("Argentina")
  userId       String
  user         User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("direcciones")
}

model Prestador {
  id          String     @id @default(uuid())
  descripcion String?
  userId      String     @unique
  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  servicios   Servicio[]
  reviews     Review[]
  favoritos   Favorito[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@map("prestadores")
}

model Favorito {
  id          String    @id @default(uuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  prestadorId String
  prestador   Prestador @relation(fields: [prestadorId], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now())

  @@unique([userId, prestadorId])
  @@map("favoritos")
}

model Review {
  id          String    @id @default(uuid())
  prestadorId String
  prestador   Prestador @relation(fields: [prestadorId], references: [id], onDelete: Cascade)
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  // 1 a 5 estrellas
  puntaje     Int
  comentario  String?
  votos       Voto[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // Una opinión por usuario y prestador; volver a opinar la reemplaza
  @@unique([prestadorId, userId])
  @@index([prestadorId])
  @@map("reviews")
}

model Voto {
  id        String   @id @default(uuid())
  reviewId  String
  review    Review   @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([reviewId, userId])
  @@index([reviewId])
  @@map("votos_reviews")
}

model Rubro {
  id        String     @id @default(uuid())
  nombre    String     @unique
  subrubros Subrubro[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@map("rubros")
}

model Subrubro {
  id        String     @id @default(uuid())
  nombre    String
  rubroId   String
  rubro     Rubro      @relation(fields: [rubroId], references: [id], onDelete: Cascade)
  servicios Servicio[]

  @@unique([rubroId, nombre])
  @@map("subrubros")
}

model Servicio {
  id               String           @id @default(uuid())
  prestadorId      String
  prestador        Prestador        @relation(fields: [prestadorId], references: [id], onDelete: Cascade)
  subrubroId       String
  subrubro         Subrubro         @relation(fields: [subrubroId], references: [id])
  zonaCobertura    String[]
  disponibilidades Disponibilidad[]
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  @@unique([prestadorId, subrubroId])
  @@map("servicios")
}

model Disponibilidad {
  id         String      @id @default(uuid())
  servicioId String
  servicio   Servicio    @relation(fields: [servicioId], references: [id], onDelete: Cascade)
  dias       DiaSemana[]
  desde      String
  hasta      String

  @@map("disponibilidades")
}

model EmailToken {
  id        String         @id @default(uuid())
  token     String         @unique
  tipo      TipoEmailToken
  userId    String
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime       @default(now())

  @@index([userId])
  @@map("email_tokens")
}

model StorageFile {
  id        String   @id @default(uuid())
  fileName  String
  path      String
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@map("storage_files")
}
