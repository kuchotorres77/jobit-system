# URL base de la API (NestJS). En dev local: npm run start:dev -w @jobit/api (puerto 3000) o docker api-nest (3005)
VITE_API_URL=http://localhost:3005/api

# Client ID de OAuth de Google (el mismo que GOOGLE_CLIENT_ID del backend)
# Vacío = botón "Iniciar sesión con Google" oculto
VITE_GOOGLE_CLIENT_ID=
